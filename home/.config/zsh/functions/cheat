cheat() {
    local location="$HOME/cheats"
    local query="${1-}"
    local selected
    selected="$(ls "$location" | fzf -1 --preview "bat --plain --color=always $location/{-1}" -q "$query")"
    if [[ -z "$selected" ]]; then
        return 1
    else
        vim "$location/$selected"
    fi   
}
