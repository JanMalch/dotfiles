#!/usr/bin/env node

const args = process.argv.slice(2);

/** Print the given `msg` to stderr in red font. */
function err(msg) {
    console.error('\x1b[31m%s\x1b[0m', msg)
}

if (args.length === 0) {
    err('received no argument')
    process.exit(1);
}

if (args.length > 2) {
    err('received more than two arguments')
    process.exit(1);
}

let useUrlAlphabet = false;
let input = "";

if (args.length === 2) {
    if (args[0] !== '-u' && args[0] !== '--url') {
        err('first of two arguments must be "-u" or "--url"')
        process.exit(1);
    }
    useUrlAlphabet = true;
    input = args[1];
} else {
    input = args[0];
}

const alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789" + (useUrlAlphabet ? '-_' : '+/')

let part = "";
let invalid = false;

function consume(p) {
    if (p) {
        try {
            console.log(atob(p).replace(/\p{C}/gu, '�'));
        } catch {
            console.log(p)
            invalid = true;
        }
    }
}

for (const c of input) {
    if (alphabet.includes(c)) {
        part += c
    } else {
        consume(part)
        console.log(c)
        part = ""
    }
}

consume(part)

process.exit(invalid ? 1 : 0)
